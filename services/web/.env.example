# Database
DATABASE_URL=postgresql://user:password@host:port/database

# Admin Authentication
ADMIN_USER_SUB=user-uuid-from-auth-service
ADMIN_EMAIL=admin@terryheath.com
AUTH_BASE_URL=https://auth.dampconcrete.com

# Mail Service
MAIL_SERVICE_URL=https://mail.dampconcrete.com
MAIL_SERVICE_SECRET=generate-a-long-random-string
INTERNAL_SECRET=generate-a-long-random-string

# Email Security
UNSUBSCRIBE_SECRET=random-32-character-secret-for-unsubscribe-tokens

# AWS SES SMTP Configuration
SES_SMTP_HOST=email-smtp.us-west-2.amazonaws.com
SES_SMTP_PORT=465
SES_SMTP_USER=your-ses-smtp-username
SES_SMTP_PASS=your-ses-smtp-password
SES_FROM_EMAIL=terry@terryheath.com

# Application
NEXT_PUBLIC_BASE_URL=https://terryheath.com

# Cron Job Security
CRON_SECRET=random-32-character-secret-for-cron-auth