DATABASE_URL=postgresql://...
PORT=3000
NODE_ENV=development

# AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Shared secret — all services must send this header
MAIL_SERVICE_SECRET=generate-a-long-random-string

# Base URL for unsubscribe links
MAIL_BASE_URL=https://mail.dampconcrete.com

# Auth service
AUTH_BASE_URL=https://auth.terryheath.com
INTERNAL_SECRET=generate-a-long-random-string
