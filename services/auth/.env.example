# Database connection string
DATABASE_URL=

# JWT secret for signing tokens
JWT_SECRET=

# Admin panel password
ADMIN_PASSWORD=

# Secret for signing admin session cookies
ADMIN_SECRET=

# Base URL of this auth service
AUTH_BASE_URL=https://auth.terryheath.com

# Application name shown in emails
APP_NAME=Small Things

# AWS SES SMTP configuration
SES_SMTP_HOST=
SES_SMTP_PORT=465
SES_SMTP_USER=
SES_SMTP_PASS=

# From email address for sending magic links
SES_FROM_EMAIL=noreply@terryheath.com

# AWS S3 configuration for uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kindle-upload
AWS_REGION=us-east-1

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://app.terryheath.com

# Node environment (production/development)
NODE_ENV=production

# Port to run the service on
PORT=3000

# Internal secret for service-to-service API calls
INTERNAL_SECRET=generate-a-long-random-string