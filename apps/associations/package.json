{
  "name": "Associations",
  "version": "1.0.0",
  "description": "A writing notebook that connects the dots",
  "author": {
    "name": "Terry Heath",
    "email": "terry@terryheath.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"sleep 3 && NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --mac --universal",
    "dist:publish": "npm run build && electron-builder --mac --universal --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^9.4.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0"
  },
  "build": {
    "appId": "com.dampconcrete.associations",
    "productName": "Associations",
    "copyright": "Copyright © 2025 Damp Concrete",
    "icon": "assets/icon.icns",
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/embeddings-worker.mjs",
        "to": "embeddings-worker.mjs"
      }
    ],
    "asarUnpack": [
      "**/@xenova/transformers/**",
      "**/sharp/**",
      "**/better-sqlite3/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "Terry Heath (CX872UNNF9)",
      "notarize": {
        "teamId": "CX872UNNF9"
      },
      "mergeASARs": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ]
    },
    "dmg": {
      "title": "Associations",
      "background": "assets/dmg-background.png",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 400
      }
    },
    "publish": {
      "provider": "s3",
      "bucket": "associations-releases",
      "region": "us-east-1"
    },
    "nsis": {
      "oneClick": false
    }
  }
}
